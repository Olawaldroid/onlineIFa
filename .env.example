# ---------------------------------------------------------------------------
# Online Ifá — environment variables
# Copy this file to `.env` and fill in real values for local development.
# Never commit your real `.env`.
# ---------------------------------------------------------------------------

# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/online_ifa?schema=public"

# Auth. Sessions are HMAC-signed cookies (src/lib/auth/session.ts); AUTH_SECRET
# signs them. A later phase can layer Auth.js (OAuth/magic-link) on the same
# helpers. Set AUTH_ENFORCED=true to require an admin login for /admin.
AUTH_SECRET="replace-with-a-long-random-string"
AUTH_URL="http://localhost:3000"
AUTH_ENFORCED="false"

# Seed account passwords (used by prisma/seed.ts). Override before seeding any
# shared/staging database.
SEED_ADMIN_PASSWORD="changeme-admin-123"
SEED_CONTRIBUTOR_PASSWORD="changeme-baba-123"

# AI assistant (retrieval-augmented; answers ONLY from approved DB content).
# The assistant is feature-flagged off by default until a provider is configured.
AI_ASSISTANT_ENABLED="false"
AI_PROVIDER="anthropic"
ANTHROPIC_API_KEY=""
AI_MODEL="claude-opus-4-8"

# Casting configuration. See src/lib/casting/config.ts for supported modes.
CASTING_DEFAULT_MODE="simulated"

# Payments (optional, later phase). Disabled by default.
PAYMENTS_ENABLED="false"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Feature flags
NEXT_PUBLIC_APP_NAME="Online Ifá"

# Private local PDF/EPUB research library (never committed).
IFA_BOOKS_PATH=C:\Users\info\Documents\Wiki\originals

# Durable contribution/review JSON file. In production, point this at a
# persistent mounted volume; temporary/serverless filesystems are unsupported.
CONTRIBUTIONS_FILE=C:\Users\info\Documents\OnlineIfaData\contributions.json
