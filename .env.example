# ---------------------------------------------------------------------------
# Online Ifá — environment variables
# Copy this file to `.env` and fill in real values for local development.
# Never commit your real `.env`.
# ---------------------------------------------------------------------------

# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/online_ifa?schema=public"

# Auth (placeholder — wire up to your provider of choice, e.g. Auth.js).
AUTH_SECRET="replace-with-a-long-random-string"
AUTH_URL="http://localhost:3000"

# AI assistant (retrieval-augmented; answers ONLY from approved DB content).
# The assistant is feature-flagged off by default until a provider is configured.
AI_ASSISTANT_ENABLED="false"
AI_PROVIDER="anthropic"
ANTHROPIC_API_KEY=""
AI_MODEL="claude-opus-4-8"

# Casting configuration. See src/lib/casting/config.ts for supported modes.
CASTING_DEFAULT_MODE="simulated"

# Payments (optional, later phase). Disabled by default.
PAYMENTS_ENABLED="false"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Feature flags
NEXT_PUBLIC_APP_NAME="Online Ifá"
